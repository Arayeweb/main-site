# Optional override; defaults to آرایه <support@araaye.com>
RESEND_FROM=آرایه <support@araaye.com>

# Suno music generation (optional — Arena music studio)
SUNO_API_KEY=
SUNO_API_BASE=https://api.sunoapi.org
# Public link for Telegram distribution banner
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/AraayeAIBot

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_BOT_USERNAME=AraayeAIBot
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id-for-lead-alerts
TELEGRAM_WEBHOOK_SECRET=random-secret-for-webhook-validation
TELEGRAM_REQUIRED_CHANNEL_ID=@araayeco
TELEGRAM_REQUIRED_SALES_CHANNEL_ID=@araayeai
TELEGRAM_SUPPORT_USERNAME=
TELEGRAM_FREE_DAILY_LIMIT=3

# Telegram lead notifier cron — bot must be member of the group
TELEGRAM_GROUP_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_CRON_SECRET=random-secret-for-cron-auth

# OpenRouter conversational AI (optional — used by the Telegram bot)
OPENROUTER_API_KEY=your-openrouter-key
# OpenRouter fetch timeouts (ms) — connect default was 10s and caused UND_ERR_CONNECT_TIMEOUT
OPENROUTER_CONNECT_TIMEOUT_MS=30000
OPENROUTER_HEADERS_TIMEOUT_MS=90000
OPENROUTER_MODEL=openai/gpt-4o

# Zibal payment gateway (used by /seo checkout and /ai credit packages)
# Use "zibal" for sandbox/test mode
ZIBAL_MERCHANT=zibal

# Araaye Arena — alert threshold for a single battle's OpenRouter cost (USD)
MAX_BATTLE_COST_USD=0.25

# Freelance scraper cron (hourly auto-scan of ponisha + karlancer)
FREELANCE_CRON_SECRET=random-secret-for-cron-auth

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN="