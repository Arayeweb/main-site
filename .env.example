# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel
ADMIN_PASSWORD=your-admin-password
ADMIN_SESSION_SECRET=random-secret-at-least-32-chars

# Site URL (used for internal API calls and lead attribution)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram bot (optional — only required for the Araye sales assistant bot)
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id-for-lead-alerts
TELEGRAM_WEBHOOK_SECRET=random-secret-for-webhook-validation

# Telegram lead notifier cron — bot must be member of the group
TELEGRAM_GROUP_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_CRON_SECRET=random-secret-for-cron-auth

# OpenRouter conversational AI (optional — used by the Telegram bot)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o

# Zibal payment gateway (optional — used by /seo checkout for paid packages)
# Use "zibal" for sandbox/test mode
ZIBAL_MERCHANT=zibal

# Freelance scraper cron (hourly auto-scan of ponisha + karlancer)
FREELANCE_CRON_SECRET=random-secret-for-cron-auth
