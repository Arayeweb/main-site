# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public Supabase URL — required by the Growth Hub browser/SSR auth clients
# (@supabase/ssr). Same value as SUPABASE_URL; must be NEXT_PUBLIC to reach the
# browser. Set on Vercel for production.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — safe to expose publicly, used for Supabase Auth signInWithPassword
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_q4CzHP0UqLHuu4XPjJHQqw_eqeSsnf5
MAX_BATTLE_COST_USD=0.25

# Araaye AI financial pricing (server-only; changing these on Vercel needs redeploy)
AI_USD_TO_TOMAN=220000
AI_COST_MULTIPLIER=2.2
AI_CREDIT_VALUE_TOMAN=1000
AI_MIN_GROSS_MARGIN=0.45
AI_PAYMENTS_ENABLED=false
LEGACY_AI_GENERATION_ENABLED=false
PUBLIC_VIDEO_GENERATION_ENABLED=false
# Keep false until wallet/lot/ledger admin adjustments are one atomic DB RPC.
AI_ADMIN_CREDIT_ADJUSTMENTS_ENABLED=false
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=آرایه <support@araaye.com>
# Admin panel
# ADMIN_SESSION_SECRET: signs HMAC session tokens — must be ≥32 random chars, keep secret
ADMIN_SESSION_SECRET=random-secret-at-least-32-chars

# Kavenegar Verify Lookup OTP for Araaye AI auth (login / register / reset)
# Docs: https://kavenegar.com/rest.html#sms-Lookup
# Create an approved template in the panel that includes %token (Araaye: otp1)
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=otp1
# ADMIN_PANEL_ACCESS_SECRET: secret code to open /admin/gate before login (≥8 chars)
ADMIN_PANEL_ACCESS_SECRET=your-private-admin-entry-code
# ADMIN_PASSWORD: legacy single-user fallback (checkAdminPassword in lib/auth.ts)
# Per-user login uses admin_users table with scrypt-hashed passwords
# Seed first admin: INSERT INTO admin_users (email, name, role, password_hash)
#   VALUES ('you@araaye.com', 'نام', 'admin', '<output of hashPassword()>');
ADMIN_PASSWORD=your-admin-password

# Blog CMS
CMS_PREVIEW_SECRET=random-preview-secret-at-least-32-chars
CMS_CRON_SECRET=random-cron-secret-for-blog-publish
CMS_UPLOAD_MAX_MB=10
CMS_APP_TIMEZONE=Asia/Tehran
CMS_AI_DAILY_BUDGET_USD=1
CMS_AI_RATE_LIMIT_PER_MIN=20

# Site URL (callbacks / local only). SEO canonical + sitemap ALWAYS use https://araaye.com
# from lib/siteUrl.ts — never paste Vercel UI masks (••••) into this var.
# Production Vercel: set exactly https://araaye.com (no www). Corrupt values are ignored.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry — error monitoring (https://araaye.sentry.io/projects/javascript-nextjs/)
NEXT_PUBLIC_SENTRY_DSN=https://6d2e6f7dd0bade5208e469dae63bd25e@o4511685465276416.ingest.us.sentry.io/4511685478973440
SENTRY_ORG=araaye
SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=  # build-time only — source map uploads (project:releases scope)
# Create at https://sentry.io/settings/account/api/auth-tokens/ or via wizard login

# PostHog — product analytics for /ai section
NEXT_PUBLIC_POSTHOG_KEY=phc_Cb9BzKixg1CJrwopeDRdAjUXqRuLqdAtF4nj9OrTlm8
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend — transactional email (verify araaye.com at https://resend.com/domains)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=آرایه <support@araaye.com>

# Optional override; defaults to آرایه <support@araaye.com>
RESEND_FROM=آرایه <support@araaye.com>

# Music generation uses OpenRouter (google/lyria-3-pro-preview) via OPENROUTER_API_KEY
# Public link for Telegram distribution banner
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/AraayeAIBot

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_BOT_USERNAME=AraayeAIBot
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id-for-lead-alerts
TELEGRAM_WEBHOOK_SECRET=random-secret-for-webhook-validation
TELEGRAM_REQUIRED_CHANNEL_ID=@araayeco
TELEGRAM_REQUIRED_SALES_CHANNEL_ID=@araayeai
TELEGRAM_SUPPORT_USERNAME=
TELEGRAM_FREE_DAILY_LIMIT=3

# Telegram lead notifier cron — bot must be member of the group
TELEGRAM_GROUP_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_CRON_SECRET=random-secret-for-cron-auth

# OpenRouter conversational AI (optional — used by the Telegram bot)
OPENROUTER_API_KEY=your-openrouter-key
# OpenRouter fetch timeouts (ms) — connect default was 10s and caused UND_ERR_CONNECT_TIMEOUT
OPENROUTER_CONNECT_TIMEOUT_MS=30000
OPENROUTER_HEADERS_TIMEOUT_MS=90000
OPENROUTER_MODEL=openai/gpt-4o

# Zibal payment gateway (used by /seo checkout and /ai credit packages)
# Use "zibal" for sandbox/test mode
ZIBAL_MERCHANT=zibal

# Payment microservice on Iranian VPS (fixed outbound IP for Zibal API)
# Phase 1 (proxy only): set URL + secret; leave PAYMENT_CALLBACKS_ENABLED unset
# Phase 2 (callbacks on VPS): also set PAYMENT_CALLBACKS_ENABLED=true
PAYMENT_SERVICE_URL=https://payment.araaye.com
PAYMENT_SERVICE_SECRET=change-me-to-64-char-random-secret
# PAYMENT_CALLBACKS_ENABLED=true

# Araaye Arena — alert threshold for a single battle's OpenRouter cost (USD)
MAX_BATTLE_COST_USD=0.25

# Freelance scraper cron (hourly auto-scan of ponisha + karlancer)
FREELANCE_CRON_SECRET=random-secret-for-cron-auth

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
